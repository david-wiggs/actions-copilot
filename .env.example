# Environment Variables for Actions Copilot

# GitHub Copilot API Configuration
LLM_API_URL=https://api.githubcopilot.com/chat/completions
LLM_API_KEY=your_github_token_here
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.2

# GitHub App Configuration
APP_ID=your_github_app_id_here
PRIVATE_KEY_PATH=path/to/your/private-key.pem
WEBHOOK_SECRET=your_webhook_secret_here

# Protection Rules Configuration
PROTECTED_ENVIRONMENTS=production,staging
BLOCK_ON_MALICIOUS=true
ALLOWED_ACTIONS=actions/checkout,actions/setup-node,actions/upload-artifact
BLOCKED_KEYWORDS=rm -rf,curl,wget,download,exec,eval

# Application Configuration
PORT=3000  # Change this to any port you prefer (e.g., 8080, 4000, etc.)
NODE_ENV=production
