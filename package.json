{
  "name": "actions-copilot",
  "version": "1.0.0",
  "description": "A Probot GitHub App that uses GitHub Copilot to protect environments from malicious GitHub Actions workflows",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "probot run ./dist/index.js",
    "dev": "nodemon --exec \"npm run build && npm start\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:live": "LIVE_API_TEST=true jest live-api.test.ts --verbose",
    "test:llm-manual": "npx tsx scripts/test-llm-manual.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "docker:build": "docker build -t actions-copilot .",
    "docker:run": "docker run -p ${PORT:-3000}:${PORT:-3000} --env-file .env actions-copilot",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "probot",
    "github",
    "bot",
    "security",
    "copilot",
    "actions",
    "environment-protection"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.0",
    "nodemon": "^3.1.10",
    "probot": "^14.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.1.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.0",
    "@types/node-fetch": "^2.6.13",
    "jest": "^30.1.2",
    "node-fetch": "^3.3.2",
    "ts-jest": "^29.4.2"
  },
  "engines": {
    "node": ">= 18"
  }
}
